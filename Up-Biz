<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AutoScale – חוו אוטומציה עכשיו</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #04101E;
      --glass-fill: rgba(90, 154, 255, 0.07);
      --glass-border: rgba(255, 255, 255, 0.15);
      --glass-shimmer: rgba(255, 255, 255, 0.32);
      --accent: #5B9CFF;
      --accent-bright: #90BFFF;
      --text-primary: #FFFFFF;
      --text-sec: #7FAACC;
      --text-dim: #3A5878;
    }

    html, body {
      min-height: 100%;
      background: var(--bg);
      color: var(--text-primary);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    }

    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 32px 20px;
      position: relative;
      overflow-x: hidden;
    }

    /* Ambient glow layers */
    body::before {
      content: '';
      position: fixed;
      top: -20%; right: -15%;
      width: 65%; height: 70%;
      background: radial-gradient(ellipse, rgba(16, 60, 180, 0.18) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      bottom: -25%; left: -15%;
      width: 55%; height: 65%;
      background: radial-gradient(ellipse, rgba(8, 30, 80, 0.22) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* Logo area */
    .logo {
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--accent);
      text-align: center;
      margin-bottom: 40px;
      position: relative;
      z-index: 1;
    }

    /* Glass card */
    .card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      background: var(--glass-fill);
      border: 0.5px solid var(--glass-border);
      border-radius: 20px;
      padding: 44px 36px 40px;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    /* Specular shimmer */
    .card::before {
      content: '';
      position: absolute;
      top: 5px;
      left: 14%; right: 14%;
      height: 1px;
      background: var(--glass-shimmer);
      border-radius: 1px;
    }
    /* Left edge shimmer */
    .card::after {
      content: '';
      position: absolute;
      top: 8%; bottom: 8%;
      right: 5px;
      width: 1px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.22), transparent 50%, rgba(255,255,255,0.06));
      border-radius: 1px;
    }

    /* Group badge */
    .group-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(91, 156, 255, 0.13);
      border: 0.5px solid rgba(91, 156, 255, 0.3);
      border-radius: 30px;
      padding: 6px 14px;
      font-size: 13px;
      color: var(--accent-bright);
      margin-bottom: 28px;
      width: 100%;
      justify-content: center;
    }

    h1 {
      font-size: 34px;
      font-weight: 700;
      line-height: 1.2;
      text-align: center;
      margin-bottom: 10px;
    }
    h1 span { color: var(--accent); }

    .sub {
      font-size: 16px;
      color: var(--text-sec);
      text-align: center;
      line-height: 1.6;
      margin-bottom: 36px;
    }

    /* Form */
    .field { margin-bottom: 18px; }

    label {
      display: block;
      font-size: 12px;
      color: var(--text-sec);
      margin-bottom: 8px;
      letter-spacing: 0.03em;
    }

    input {
      width: 100%;
      background: rgba(255, 255, 255, 0.05);
      border: 0.5px solid rgba(255, 255, 255, 0.14);
      border-radius: 12px;
      padding: 15px 18px;
      font-size: 16px;
      color: var(--text-primary);
      outline: none;
      transition: border-color 0.2s, background 0.2s;
      font-family: inherit;
      text-align: right;
      -webkit-appearance: none;
    }
    input::placeholder { color: rgba(255,255,255,0.22); }
    input:focus {
      border-color: rgba(91, 156, 255, 0.45);
      background: rgba(91, 156, 255, 0.06);
    }

    /* Submit button */
    .btn {
      width: 100%;
      margin-top: 28px;
      background: #1A73E8;
      border: none;
      border-radius: 14px;
      padding: 17px;
      font-size: 17px;
      font-weight: 600;
      color: #fff;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.2s, transform 0.12s;
      position: relative;
      overflow: hidden;
    }
    .btn::before {
      content: '';
      position: absolute;
      top: 0; left: 10%; right: 10%;
      height: 1px;
      background: rgba(255,255,255,0.3);
    }
    .btn:hover { opacity: 0.92; }
    .btn:active { transform: scale(0.98); }
    .btn:disabled { opacity: 0.45; cursor: default; transform: none; }

    /* Success state */
    #success {
      display: none;
      text-align: center;
      padding: 16px 0;
    }
    #success .icon { font-size: 58px; margin-bottom: 20px; display: block; }
    #success h2 { font-size: 26px; margin-bottom: 10px; }
    #success p { color: var(--text-sec); font-size: 16px; line-height: 1.7; }
    #success .wow {
      margin-top: 24px;
      font-size: 14px;
      color: var(--accent);
      padding: 12px 20px;
      background: rgba(91, 156, 255, 0.1);
      border-radius: 10px;
      border: 0.5px solid rgba(91, 156, 255, 0.2);
    }

    /* Footer */
    .footer {
      margin-top: 28px;
      font-size: 11px;
      color: var(--text-dim);
      letter-spacing: 0.08em;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    @media (max-width: 480px) {
      .card { padding: 36px 24px 32px; }
      h1 { font-size: 28px; }
    }
  </style>
</head>
<body>

  <div class="logo">AUTOSCALE</div>

  <div class="card">

    <!-- Form -->
    <div id="form-section">
      <div class="group-badge">⚡ מיוחד לחברי קבוצת Up – לעסקים</div>

      <h1>חוו <span>אוטומציה</span><br>עכשיו</h1>
      <p class="sub">מלאו שם ומספר טלפון. תראו מה קורה תוך 30 שניות.</p>

      <div class="field">
        <label>שם מלא</label>
        <input type="text" id="name" placeholder="הכניסו את שמכם" autocomplete="name" inputmode="text">
      </div>
      <div class="field">
        <label>מספר טלפון</label>
        <input type="tel" id="phone" placeholder="05X-XXXXXXX" autocomplete="tel" inputmode="tel">
      </div>

      <button class="btn" id="submit-btn" onclick="handleSubmit()">שליחה ←</button>
    </div>

    <!-- Success -->
    <div id="success">
      <span class="icon">📲</span>
      <h2>בדרך אליך</h2>
      <p>תוך שניות ספורות<br>תקבלו הודעת ווצאפ.</p>
      <div class="wow">זו לא הבטחה. זו הדגמה בזמן אמת.</div>
    </div>

  </div>

  <div class="footer">autoscalehq.io</div>

  <script>
    async function handleSubmit() {
      const name  = document.getElementById('name').value.trim();
      const phone = document.getElementById('phone').value.trim();

      if (!name)  { document.getElementById('name').focus();  return; }
      if (!phone) { document.getElementById('phone').focus(); return; }

      const btn = document.getElementById('submit-btn');
      btn.disabled    = true;
      btn.textContent = 'שולח...';

      const payload = {
        name:  name,
        phone: phone,
        Type:  'אחרי שיחה'
      };

      try {
        await fetch('https://hook.eu1.make.com/w9giggm11dd63tjqgf2gmqfnhgeva9gs', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
          mode:    'no-cors'   // webhook may not send CORS headers
        });
      } catch (_) {
        // no-cors mode throws on network errors only; proceed to success
      }

      document.getElementById('form-section').style.display = 'none';
      document.getElementById('success').style.display      = 'block';
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Enter') handleSubmit();
    });
  </script>

</body>
</html>
